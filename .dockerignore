# Files excluded from the Docker build context.
# Keeping virtualenvs, caches, logs, secrets, and local outputs out of the image
# makes builds smaller and avoids accidentally copying private config.
.venv
__pycache__
*.pyc
.git
.gitignore
.env
.env.*
uv.lock.bak
logs
outputs
eval_results
.pytest_cache
.mypy_cache
.ruff_cache
