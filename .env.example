# Example environment variables for local development and Docker Compose.
# Copy this to `.env`, fill in real secrets, and adjust gateway/cache URLs based
# on whether you run services locally or inside Docker.
APP_NAME=Agentic RAG System
APP_ENV=local
LOG_LEVEL=INFO
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=storage/chroma
CHROMA_COLLECTION=agentic_rag_docs
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_K=5
MIN_RETRIEVAL_SCORE=0.35
GUARDRAILS_ENABLED=true

# LLM Gateway Config
LLM_GATEWAY_URL=http://localhost:4000/v1  # for local
# LLM_GATEWAY_URL=http://litellm-gateway:4000/v1  # this is for docker.
LITELLM_MASTER_KEY=sk-local-litellm-master-key
# Optional separate key FastAPI should use when calling LiteLLM. If omitted,
# the app falls back to LITELLM_MASTER_KEY for gateway calls.
LLM_GATEWAY_API_KEY=sk-local-litellm-master-key
UI_USERNAME=admin
UI_PASSWORD=password

# db for LLM-GW
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/litellm-gw


# Langfuse Config
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Redis Config (Used by LiteLLM Gateway for caching)
REDIS_URL=redis://localhost:6379/0
